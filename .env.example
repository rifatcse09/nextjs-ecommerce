# Generate a strong secret with: openssl rand -base64 32
JWT_SECRET=your-strong-secret-key-here

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
